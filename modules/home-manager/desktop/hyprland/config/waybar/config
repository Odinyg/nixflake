{
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "height": 30,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "backlight",
        "pulseaudio",
        "bluetooth",
        "network",
        "battery",
        "tray"
    ],
    "hyprland/window": {
        "format": "{}",
        "max-length": 35,
        "rewrite": {
            "": "Hyprland"
        },
        "separate-outputs": true
    },
    "hyprland/workspaces": {
        "format": "{icon}",
        "all-outputs": false,
        "show-special": false,
        "on-click": "activate",
        "format-icons": {
            "active": " "
        },
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": 4
        }
    },
    "clock": {
        "format": "{:%d-%m σ±®¥ %V  %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "on-click": "gnome-calendar",
        "format-alt": "{:%d-%m-%Y}",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    },
    "tray": {
        "icon-size": 16,
        "spacing": 5
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-full": "σΑ¹Ι  {capacity}%",
        "format-charging": "σΑ²³  {capacity}%",
        "format-plugged": "σΑöΞ  {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
        "on-click": "kitty --class waybar-popup -o remember_window_size=no -o initial_window_width=800 -o initial_window_height=500 -e bash -c 'upower -i $(upower -e | grep battery) && read -p \"Press enter to close\"'"
    },
    "network": {
        "format-wifi": "σΑΛ®  {signalStrength}%",
        "format-ethernet": "σΑàÄ {cidr}",
        "tooltip-format": "{ifname} via {gwaddr} \n{ipaddr}/{cidr}",
        "format-linked": "{ifname} (No IP) ",
        "format-disconnected": "σΑΛ≠ ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "kitty --class waybar-popup -o remember_window_size=no -o initial_window_width=800 -o initial_window_height=500 -e nmtui"
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "σΑ²· {volume}% {format_source}",
        "format-bluetooth-muted": "σΑ²≤ {format_source}",
        "format-muted": "σΑùü  muted",
        "format-icons": {
            "headphone": "σΑ΄΄",
            "hands-free": "σΑ΄é",
            "headset": "σΑ΄é",
            "phone": "σΑè≤",
            "portable": "σΑè≤",
            "car": "σΑ³΄",
            "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
        },
        "on-click": "kitty --class waybar-popup -o remember_window_size=no -o initial_window_width=800 -o initial_window_height=500 -e pulsemixer",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },
    "bluetooth": {
        "format": "σΑ²·",
        "format-connected": "σΑ²± {num_connections}",
        "format-disabled": "σΑ²≤",
        "tooltip-format": "{controller_alias}\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click": "kitty --class waybar-popup -o remember_window_size=no -o initial_window_width=800 -o initial_window_height=500 -e bluetuith"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}  {percent}%",
        "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-"
    }
}
