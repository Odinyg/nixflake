{
  "permissions": {
    "allow": [
      "mcp__nixos__nix",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:wiki.nixos.org)",
      "WebFetch(domain:discourse.nixos.org)",
      "WebFetch(domain:gethomepage.dev)",
      "WebFetch(domain:hyprpanel.com)",
      "Bash(just rebuild:*)",
      "Bash(just verbose:*)",
      "Bash(colmena apply:*)",
      "Bash(nix flake check:*)",
      "Bash(nix flake show:*)",
      "Bash(nix eval:*)",
      "Bash(nix fmt:*)",
      "Bash(nix build:*)",
      "Bash(nix run:*)",
      "Bash(nix develop:*)",
      "Bash(nix path-info:*)",
      "Bash(nix derivation:*)",
      "Bash(nix store:*)",
      "Bash(git add:*)",
      "Bash(gh api:*)",
      "Skill(server-plan-service)",
      "Skill(server-new-service)",
      "Bash(nix log:*)",
      "WebFetch(domain:mynixos.com)",
      "WebFetch(domain:api.github.com)",
      "Bash(nix-prefetch-url:*)",
      "Bash(nix hash:*)",
      "Bash(just deploy:*)",
      "Read(//tmp/**)",
      "Bash(nix search:*)",
      "Bash(journalctl -u prometheus-nextcloud-exporter -n 50)",
      "Skill(cleanup-nixos-config)",
      "Bash(nmcli connection:*)",
      "Bash(nmcli device:*)",
      "Bash(dmesg)",
      "Bash(ip addr:*)",
      "Bash(systemctl status:*)",
      "Bash(systemctl is-enabled:*)",
      "Bash(nixfmt:*)",
      "mcp__github__search_repositories",
      "Bash(curl -s https://wiki.nixos.org/wiki/Microvm)",
      "WebFetch(domain:www.nijho.lt)",
      "WebFetch(domain:microvm-nix.github.io)",
      "WebFetch(domain:blog.arsfeld.dev)",
      "WebFetch(domain:docs.clan.lol)",
      "WebFetch(domain:clan.lol)",
      "Bash(wc:*)",
      "Bash(nix flake:*)",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\(d[''''locks''''][''''nodes''''].get\\(''''nixpkgs-unstable'''',{}\\).get\\(''''locked'''',{}\\).get\\(''''rev'''',''''''''\\)\\)\")",
      "Bash(git commit:*)",
      "Bash(curl -s https://docs.netbird.io/selfhosted/identity-providers)",
      "Bash(curl -s https://docs.netbird.io/selfhosted/selfhosted-guide)",
      "WebFetch(domain:www.authelia.com)",
      "WebFetch(domain:docs.netbird.io)",
      "WebFetch(domain:forum.netbird.io)"
    ],
    "deny": [],
    "ask": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "nixos"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; [[ \"$f\" == *.nix ]] && nix fmt -- \"$f\" 2>/dev/null || true; }",
            "timeout": 30,
            "statusMessage": "Formatting .nix file..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; [[ \"$f\" == /home/none/nixflake/* ]] && git -C /home/none/nixflake ls-files --error-unmatch \"$f\" 2>/dev/null || git -C /home/none/nixflake add \"$f\" 2>/dev/null; true; }",
            "timeout": 10,
            "statusMessage": "Staging new file..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; [[ \"$f\" == */secrets/*.yaml ]] && echo '{\"decision\":\"block\",\"reason\":\"This is a sops-encrypted secrets file. Use just secrets-<host> to edit.\"}' || true; }"
          }
        ]
      }
    ]
  }
}
